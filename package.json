{
  "name": "multimarker",
  "displayName": "Multimarker",
  "description": "Mark positions with convenient keyboard shortcuts, then replace marks with multiple cursors",
  "version": "0.0.1",
  "engines": { "vscode": "^1.74.0" },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "multimarker.markPosition",
        "title": "Multi-Cursor: Mark Position"
      },
      {
        "command": "multimarker.applyCursors",
        "title": "Multi-Cursor: Apply All Cursors"
      },
      {
        "command": "multimarker.clearMarks",
        "title": "Multi-Cursor: Clear All Marks"
      },
      {
        "command": "multimarker.markAndGotoNext",
        "title": "Multi-Cursor: Mark Symbol Under Cursor And Jump To Next"
      },
      {
        "command": "multimarker.markAndGotoPrev",
        "title": "Multi-Cursor: Mark Symbol Under Cursor And Jump To Previous"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@types/node": "16.x",
    "typescript": "^4.9.4"
  }
}